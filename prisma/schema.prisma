// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id        String   @id @default(uuid())
  title     String
  platform  String
  year      Int
  status    String   @default("PENDING") // Podríamos usar Enums de Postgres luego
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}